                    'Q': ['01110','10001','10101','10010','01101'],
                    'R': ['11110','10001','11110','10010','10001'],
                    'S': ['01111','10000','01110','00001','11110'],
                    'T': ['11111','00100','00100','00100','00100'],
                    'U': ['10001','10001','10001','10001','01110'],
                    'V': ['10001','10001','10001','01010','00100'],
                    'W': ['10001','10001','10101','11011','10001'],
                    'X': ['10001','01010','00100','01010','10001'],
                    'Y': ['10001','01010','00100','00100','00100'],
                    'Z': ['11111','00010','00100','01000','11111'],
                    ' ': ['00000','00000','00000','00000','00000'],
                    '!': ['00100','00100','00100','00000','00100'],
                    '.': ['00000','00000','00000','00000','00100'],
                    '-': ['00000','00000','11111','00000','00000'],
                }
            },
        };

        const COLOR_THEMES = [
            { name: '青色', color: '#22d3ee' },
            { name: '紫色', color: '#a78bfa' },
            { name: '绿色', color: '#10b981' },
            { name: '橙色', color: '#f97316' },
            { name: '红色', color: '#ef4444' },
            { name: '粉色', color: '#ec4899' },
            { name: '金色', color: '#fbbf24' },
            { name: '白色', color: '#e5e7eb' },
            { name: '彩虹', color: 'rainbow' },
        ];

        let currentFont = 'block';
        let currentTheme = '#22d3ee';
        let history = JSON.parse(localStorage.getItem('asciicraft_history') || '[]');
        let uploadedImage = null;

        // ========== 初始化渲染 ==========
        function renderFontGrid() {
            document.getElementById('fontGrid').innerHTML = Object.entries(FONTS).map(([key, font]) =>
                `<div class="font-item ${currentFont === key ? 'active' : ''}" onclick="setFont('${key}')">${font.name}</div>`
            ).join('');
        }

        function renderThemes() {
            document.getElementById('themeRow').innerHTML = COLOR_THEMES.map(t =>
                `<button class="theme-btn ${currentTheme === t.color ? 'active' : ''}" onclick="setTheme('${t.color}')" style="${t.color !== 'rainbow' ? 'border-color:'+t.color+'40;' : ''}">${t.name}</button>`
            ).join('');
        }

        function setFont(f) {
            currentFont = f;
            renderFontGrid();
            generateText();
        }

        function setTheme(color) {
            currentTheme = color;
            renderThemes();
            applyTheme();
        }

        function applyTheme() {
            const output = document.getElementById('asciiOutput');
            if (currentTheme === 'rainbow') {
                const text = output.textContent;
                const lines = text.split('\n');
                const colors = ['#ef4444','#f97316','#fbbf24','#22c55e','#3b82f6','#8b5cf6','#ec4899'];
                let html = '';
                lines.forEach((line, li) => {
                    const c = colors[li % colors.length];
                    html += `<span style="color:${c}">${escHtml(line)}</span>\n`;
                });
                output.innerHTML = html;
            } else {
                output.style.color = currentTheme;
            }
        }

        // ========== 文字生成 ==========
        function generateText() {
            const text = document.getElementById('textInput').value.toUpperCase();
            const font = FONTS[currentFont];
            const fillChar = document.getElementById('fillChar').value;
            const spacing = parseInt(document.getElementById('hSpacing').value);

            if (!text) {
                document.getElementById('asciiOutput').textContent = '输入文字后生成 ASCII 艺术...';
                return;
            }

            const lines = [];
            for (let row = 0; row < font.height; row++) {
                let line = '';
                for (let ci = 0; ci < text.length; ci++) {
                    const ch = text[ci];
                    const charDef = font.chars[ch] || font.chars[' '];
                    if (charDef && charDef[row]) {
                        for (let col = 0; col < charDef[row].length; col++) {
                            line += charDef[row][col] === '1' ? fillChar : ' ';
                        }
                    }
                    // 字间距
                    line += ' '.repeat(spacing);
                }
                lines.push(line);
            }

            const result = lines.join('\n');
            const output = document.getElementById('asciiOutput');
            output.textContent = result;
            applyTheme();

            // 添加历史
            addHistory(text, currentFont);
        }

        // ========== 图片转 ASCII ==========
        const IMG_CHARSETS = {
            standard: ' .:-=+*#%@',
            detailed: ' .\'`^",:;Il!i><~+_-?][}{1)(|\\/tfjrxnuvczXYUJCLQ0OZmwqpdbkhao*#MW&8%B@$',
            blocks: ' ░▒▓█',
            simple: ' .*#@',
        };

        const dropZone = document.getElementById('dropZone');
        dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('over'); });
        dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('over'); });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('over');
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) processImage(file);
        });

        function processImage(file) {
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                const img = new Image();
                img.onload = () => {
                    uploadedImage = img;
                    document.getElementById('imgControls').style.display = 'flex';
                    dropZone.innerHTML = `✅ 已加载: ${file.name} (${img.width}×${img.height})`;
                    convertImageToAscii(img);
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        function reprocessImage() {
            if (uploadedImage) convertImageToAscii(uploadedImage);
        }

        function convertImageToAscii(img) {
            const canvas = document.getElementById('imgCanvas');
            const ctx = canvas.getContext('2d');
            const targetWidth = parseInt(document.getElementById('imgWidth').value);
            const aspectRatio = img.height / img.width;
            const targetHeight = Math.floor(targetWidth * aspectRatio * 0.5); // 字符高度约为宽度2倍

            canvas.width = targetWidth;
            canvas.height = targetHeight;

            // 对比度
            const contrast = parseInt(document.getElementById('imgContrast').value);
            ctx.filter = `contrast(${contrast}%)`;
            ctx.drawImage(img, 0, 0, targetWidth, targetHeight);

            const imageData = ctx.getImageData(0, 0, targetWidth, targetHeight);
            const pixels = imageData.data;
            const charset = IMG_CHARSETS[document.getElementById('imgCharset').value];

            let ascii = '';
            for (let y = 0; y < targetHeight; y++) {
                for (let x = 0; x < targetWidth; x++) {
                    const idx = (y * targetWidth + x) * 4;
                    const r = pixels[idx];
                    const g = pixels[idx + 1];
                    const b = pixels[idx + 2];
                    const brightness = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
                    const charIdx = Math.floor(brightness * (charset.length - 1));
                    ascii += charset[charIdx];
                }
                ascii += '\n';
            }

            const output = document.getElementById('imgAsciiOutput');
            output.textContent = ascii;
            output.classList.add('show');
            output.style.color = currentTheme === 'rainbow' ? '#22d3ee' : currentTheme;
            showToast(`🖼 生成完成: ${targetWidth}×${targetHeight} 字符`);
        }

        function copyImgAscii() {
            const text = document.getElementById('imgAsciiOutput').textContent;
            navigator.clipboard.writeText(text).then(() => showToast('📋 字符画已复制'));
        }

        // ========== 历史记录 ==========
        function addHistory(text, font) {
            const exists = history.find(h => h.text === text && h.font === font);
            if (exists) return;
            history.unshift({ text, font, time: Date.now() });
            if (history.length > 20) history.pop();
            localStorage.setItem('asciicraft_history', JSON.stringify(history));
            renderHistory();
        }

        function renderHistory() {
            const list = document.getElementById('historyList');
            if (history.length === 0) {
                list.innerHTML = '<div class="hist-empty">暂无历史记录</div>';
                return;
            }
            list.innerHTML = history.slice(0, 10).map((h, i) => `
                <div class="hist-item" onclick="loadHistory(${i})">
                    <div>
                        <span class="hist-text">${escHtml(h.text)}</span>
                        <span class="hist-font"> · ${FONTS[h.font]?.name || h.font}</span>
                    </div>
                    <span style="font-size:11px;color:#334;">${timeAgo(h.time)}</span>
                </div>
            `).join('');
        }

        function loadHistory(i) {
            const h = history[i];
            document.getElementById('textInput').value = h.text;
            currentFont = h.font;
            renderFontGrid();
            generateText();
            showToast(`📜 已加载: ${h.text}`);
        }

        function clearHistory() {
            history = [];
            localStorage.removeItem('asciicraft_history');
            renderHistory();
            showToast('🗑 历史已清空');
        }

        // ========== 导出 ==========
        function copyAscii() {
            const text = document.getElementById('asciiOutput').textContent;
            navigator.clipboard.writeText(text).then(() => showToast('📋 ASCII 已复制'));
        }

        function downloadTxt() {
            const text = document.getElementById('asciiOutput').textContent;
            const blob = new Blob([text], { type: 'text/plain' });
            const a = document.createElement('a');
            a.download = 'ascii-art.txt';
            a.href = URL.createObjectURL(blob);
            a.click();
            showToast('💾 TXT 已下载');
        }

        function downloadHTML() {
            const text = document.getElementById('asciiOutput').textContent;
            const color = currentTheme === 'rainbow' ? '#22d3ee' : currentTheme;
            const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>ASCII Art</title>
<style>body{background:#0a0a12;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;}
pre{font-family:'Courier New',monospace;font-size:14px;line-height:1.2;color:${color};}</style>
</head><body><pre>${escHtml(text)}</pre></body></html>`;
            const blob = new Blob([html], { type: 'text/html' });
            const a = document.createElement('a');
            a.download = 'ascii-art.html';
            a.href = URL.createObjectURL(blob);
            a.click();
            showToast('🌐 HTML 已下载');
        }

        // ========== 工具 ==========
        function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
        function timeAgo(ts) {
            const diff = Date.now() - ts;
            if (diff < 60000) return '刚刚';
            if (diff < 3600000) return Math.floor(diff/60000) + '分钟前';
            if (diff < 86400000) return Math.floor(diff/3600000) + '小时前';
            return Math.floor(diff/86400000) + '天前';
        }
        function showToast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg; t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 2200);
        }

        // ========== 初始化 ==========
        renderFontGrid();
        renderThemes();
        renderHistory();
        generateText();
    </script>
</body>
</html>
