<body>
    <header>
        <h1>✨ Ascii<span>Craft</span></h1>
        <p>ASCII 艺术文字 & 图片转字符画生成器</p>
    </header>

    <div class="container">
        <!-- 文字输入 -->
        <div class="input-card">
            <div class="input-row">
                <input class="text-input" id="textInput" value="HELLO" placeholder="输入英文字母..." oninput="generateText()">
                <button class="gen-btn" onclick="generateText()">🎨 生成</button>
            </div>

            <div class="font-section">
                <div class="font-label">🔤 字体风格</div>
                <div class="font-grid" id="fontGrid"></div>
            </div>

            <div class="settings-row">
                <div class="setting-item">
                    <span class="setting-lbl">水平间距:</span>
                    <select class="setting-select" id="hSpacing" onchange="generateText()">
                        <option value="0">紧凑</option>
                        <option value="1" selected>正常</option>
                        <option value="2">宽松</option>
                        <option value="3">超宽</option>
                    </select>
                </div>
                <div class="setting-item">
                    <span class="setting-lbl">填充字符:</span>
                    <select class="setting-select" id="fillChar" onchange="generateText()">
                        <option value="█">█ 实心</option>
                        <option value="#"># 井号</option>
                        <option value="*">* 星号</option>
                        <option value="@">@ 圈A</option>
                        <option value="■">■ 方块</option>
                        <option value="●">● 圆点</option>
                        <option value="0">0 数字</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- 颜色主题 -->
        <div class="preview-card">
            <div class="preview-header">
                <div class="preview-title">🎯 ASCII 艺术输出</div>
                <div class="preview-btns">
                    <button class="pv-btn" onclick="copyAscii()">📋 复制</button>
                    <button class="pv-btn" onclick="downloadTxt()">💾 下载 .txt</button>
                    <button class="pv-btn" onclick="downloadHTML()">🌐 下载 HTML</button>
                </div>
            </div>
            <div class="theme-section">
                <div class="font-label">🎨 颜色主题</div>
                <div class="theme-row" id="themeRow"></div>
            </div>
            <div class="ascii-output" id="asciiOutput">输入文字后生成 ASCII 艺术...</div>
        </div>

        <!-- 图片转 ASCII -->
        <div class="img-card">
            <h3>🖼 图片转 ASCII 字符画</h3>
            <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                📁 点击上传或拖拽图片到此处
                <br><span style="font-size:11px;color:#222;">(支持 JPG / PNG / GIF)</span>
            </div>
            <input type="file" id="fileInput" accept="image/*" style="display:none;" onchange="processImage(this.files[0])">
            <div class="img-controls" id="imgControls" style="display:none;">
                <div class="img-slider-wrap">
                    <label>宽度:</label>
                    <input type="range" class="img-slider" id="imgWidth" min="40" max="200" value="100" oninput="document.getElementById('imgWidthVal').textContent=this.value;reprocessImage();">
                    <span class="img-val" id="imgWidthVal">100</span>
                </div>
                <div class="img-slider-wrap">
                    <label>对比度:</label>
                    <input type="range" class="img-slider" id="imgContrast" min="0" max="200" value="100" oninput="document.getElementById('imgContrastVal').textContent=this.value+'%';reprocessImage();">
                    <span class="img-val" id="imgContrastVal">100%</span>
                </div>
                <div class="setting-item">
                    <span class="setting-lbl">字符集:</span>
                    <select class="setting-select" id="imgCharset" onchange="reprocessImage()">
                        <option value="standard">标准</option>
                        <option value="detailed">精细</option>
                        <option value="blocks">方块</option>
                        <option value="simple">简约</option>
                    </select>
                </div>
                <button class="pv-btn" onclick="copyImgAscii()">📋 复制</button>
            </div>
            <div class="img-ascii-output" id="imgAsciiOutput"></div>
        </div>

        <!-- 历史 -->
        <div class="history-card">
            <h3>
                📜 生成历史
                <button class="clear-hist" onclick="clearHistory()">🗑 清空</button>
            </h3>
            <div class="history-list" id="historyList">
                <div class="hist-empty">暂无历史记录</div>
            </div>
        </div>
    </div>

